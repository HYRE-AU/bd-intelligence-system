{
  "outputDirectory": ".",
  "functions": {
    "api/cron.ts": {
      "maxDuration": 60,
      "includeFiles": "src/**"
    }
  },
  "crons": [
    { "path": "/api/cron?pipeline=yc-jobs",    "schedule": "0 22 * * *"  },
    { "path": "/api/cron?pipeline=digest",     "schedule": "5 22 * * *"  },
    { "path": "/api/cron?pipeline=hn-funding", "schedule": "0 22 * * *"  },
    { "path": "/api/cron?pipeline=hn-signals", "schedule": "0 22 * * *"  }
  ]
}
